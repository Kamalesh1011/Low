# ── App ────────────────────────────────────────────────────
APP_NAME="OmniForge Nexus"
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://omniforge:omniforge123@localhost:5432/omniforge_nexus
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AI ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-4o
PLANNER_MODEL=openai/gpt-4o
ARCHITECT_MODEL=anthropic/claude-3.5-sonnet
BUILDER_MODEL=openai/gpt-4o
VALIDATOR_MODEL=deepseek/deepseek-r1
MAX_TOKENS=128000
TEMPERATURE=0.7

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-32-chars-minimum-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Vault ────────────────────────────────────────────────────
VAULT_ENCRYPTION_KEY=your-aes-256-encryption-key-32-bytes!!

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_BUILD_TOPIC=omniforge.builds
KAFKA_AGENT_TOPIC=omniforge.agents
KAFKA_WORKFLOW_TOPIC=omniforge.workflows

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

# ── Storage ─────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=omniforge-nexus
AWS_REGION=ap-south-1
